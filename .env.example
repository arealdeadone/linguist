# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/linguist

# Redis (optional — skip for Vercel deployment)
REDIS_URL=redis://localhost:6379

# Agoda GenAI Gateway
AGODA_GENAI_API_KEY=your-api-key
GENAI_BASE_URL=https://genai-gateway.agoda.is/v1

# AI Mode: 'local' (direct calls) or 'queue' (via ai_jobs table)
AI_MODE=local

# Supabase (for auth)
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key
ADMIN_SUPABASE_USER_ID=your-admin-user-id

# Worker tuning (used only when AI_MODE=queue)
POLL_INTERVAL_MS=2000
MAX_CONCURRENT_JOBS=3
STALE_JOB_MINUTES=5

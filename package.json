{
	"name": "linguist",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"workspaces": [
		"packages/*",
		"worker"
	],
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"test": "vitest run --passWithNoTests",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"db:generate": "drizzle-kit generate",
		"db:push": "drizzle-kit push",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"db:seed": "tsx scripts/seed.ts",
		"docker:up": "docker compose up -d",
		"docker:down": "docker compose down",
		"k8s:deploy": "bash scripts/deploy.sh",
		"k8s:deploy:seed": "bash scripts/deploy.sh --seed",
		"k8s:logs": "kubectl logs -f -n linguist deployment/linguist-app",
		"k8s:seed": "kubectl exec -n linguist deployment/linguist-app -- node -e \"require('./build/server/chunks/seed.js')\"",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.2",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^22",
		"drizzle-kit": "^0.31.10",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.3.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.2.2",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^7.3.1",
		"vitest": "^3.2.4"
	},
	"dependencies": {
		"@supabase/ssr": "^0.9.0",
		"@supabase/supabase-js": "^2.100.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"drizzle-orm": "^0.45.1",
		"hanzi-writer": "^3.7.3",
		"ioredis": "^5.10.1",
		"magic-bytes.js": "^1.13.0",
		"openai": "^6.32.0",
		"postgres": "^3.4.8",
		"zod": "^4.3.6"
	}
}
